{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kycshield.ai/schemas/v1/evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_id",
    "finding_id",
    "evidence_type",
    "mime_type",
    "storage_ref",
    "description",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "evidence_id": { "type": "string", "format": "uuid" },
    "finding_id": { "type": "string", "format": "uuid" },
    "evidence_type": {
      "type": "string",
      "enum": ["crop", "ela_heatmap", "metadata_snapshot", "pdf_object_ref", "ocr_snippet", "overlay", "comparison_side_by_side"]
    },
    "mime_type": {
      "type": "string",
      "enum": ["image/png", "image/jpeg", "application/json", "text/plain"]
    },
    "storage_ref": { "type": "string" },
    "description": { "type": "string" },
    "related_regions": {
      "type": "array",
      "items": { "$ref": "finding.schema.json#/$defs/region" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
