{
  "$id": "https://kycshield.ai/schemas/v1/forensics.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForensicResult",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "forensic_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "metadata_snapshot": {
      "type": "object",
      "properties": {
        "file_type": { "type": "string", "enum": ["image", "pdf", "unknown"] },
        "raw_metadata": { "type": "object" }
      },
      "required": ["file_type", "raw_metadata"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "finding_id": { "type": "string", "format": "uuid" },
          "signal_id": { "type": "string" },
          "finding_name": { "type": "string" },
          "severity": { "type": "string", "enum": ["INFO", "LOW", "MEDIUM", "HIGH"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": { "type": "object" },
          "source": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["signal_id", "severity", "evidence", "source", "confidence"]
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_version",
    "forensic_id",
    "document_id",
    "metadata_snapshot",
    "findings",
    "created_at"
  ],
  "additionalProperties": false
}
