{
  "$id": "https://kycshield.ai/schemas/v1/classification.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentClassification",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "classification_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "document_type": { "type": "string", "enum": ["aadhaar", "pan", "bank_statement", "unknown"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "classifier_version": { "type": "string" },
    "signals": {
      "type": "object",
      "properties": {
        "matched_keywords": { "type": "array", "items": { "type": "string" } },
        "matched_patterns": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["matched_keywords", "matched_patterns"],
      "additionalProperties": false
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_version",
    "classification_id",
    "document_id",
    "document_type",
    "confidence",
    "classifier_version",
    "signals",
    "created_at"
  ],
  "additionalProperties": false
}
