{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kycshield.ai/schemas/v1/cross_document_finding.schema.json",
  "title": "CrossDocumentFinding",
  "type": "object",
  "required": [
    "schema_version",
    "finding_id",
    "category",
    "title",
    "description",
    "severity",
    "confidence",
    "confidence_qualifier",
    "signals_triggered",
    "documents_involved",
    "consistency_field",
    "evidence_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "finding_id": { "type": "string", "format": "uuid" },
    "category": { "type": "string", "const": "content_manipulation" },
    "title": { "type": "string", "maxLength": 120 },
    "description": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "critical"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_qualifier": { "type": "string", "enum": ["high", "medium", "low"] },
    "signals_triggered": {
      "type": "array",
      "items": { "type": "string", "const": "S14" },
      "minItems": 1
    },
    "documents_involved": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "minItems": 2
    },
    "consistency_field": {
      "type": "string",
      "enum": ["name", "dob", "pan", "address", "account_holder"]
    },
    "field_values": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "limitations": { "type": "string" },
    "benign_alternatives": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
