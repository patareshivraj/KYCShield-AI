{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kycshield.ai/schemas/v1/document_page.schema.json",
  "title": "DocumentPage",
  "type": "object",
  "required": ["schema_version", "page_id", "document_id", "page_index", "width_px", "height_px", "storage_ref"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "page_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "page_index": { "type": "integer", "minimum": 0 },
    "width_px": { "type": "integer", "minimum": 1 },
    "height_px": { "type": "integer", "minimum": 1 },
    "dpi_estimate": { "type": "number", "minimum": 0 },
    "storage_ref": { "type": "string" },
    "derived_from_pdf": { "type": "boolean", "default": false }
  }
}
