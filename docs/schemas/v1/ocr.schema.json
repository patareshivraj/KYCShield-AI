{
  "$id": "https://kycshield.ai/schemas/v1/ocr.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OCRResult",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "ocr_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "engine_used": { "type": "string" },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field_name": { "type": "string" },
          "field_value": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "is_valid": { "type": "boolean" },
          "evidence": {
            "type": "object",
            "properties": {
              "source_text": { "type": "string" },
              "bbox": { "type": "array", "items": { "type": "array", "items": { "type": "number" } } },
              "page_index": { "type": "integer" }
            }
          }
        },
        "required": ["field_name", "field_value", "confidence", "is_valid", "evidence"]
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_version",
    "ocr_id",
    "document_id",
    "engine_used",
    "overall_confidence",
    "fields",
    "created_at"
  ],
  "additionalProperties": false
}
