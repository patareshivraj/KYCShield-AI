{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kycshield.ai/schemas/v1/signal_result.schema.json",
  "title": "SignalResult",
  "type": "object",
  "required": [
    "schema_version",
    "signal_id",
    "signal_version",
    "document_id",
    "status",
    "severity",
    "confidence",
    "tier",
    "observations",
    "quality_sensitive",
    "duration_ms"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "signal_id": { "type": "string", "pattern": "^S[0-9]{2}$" },
    "signal_version": { "type": "string" },
    "document_id": { "type": "string", "format": "uuid" },
    "status": { "type": "string", "enum": ["completed", "degraded", "skipped", "failed"] },
    "severity": {
      "type": "string",
      "enum": ["none", "informational", "low", "medium", "high", "critical"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "tier": { "type": "string", "enum": ["A", "B", "C", "D", "-"] },
    "category": {
      "type": "string",
      "enum": [
        "quality_gate",
        "visual_forgery",
        "metadata_manipulation",
        "content_manipulation",
        "layout_manipulation",
        "synthetic_generation",
        "infrastructure"
      ]
    },
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "value"],
        "properties": {
          "key": { "type": "string" },
          "value": {}
        }
      }
    },
    "regions": {
      "type": "array",
      "items": { "$ref": "finding.schema.json#/$defs/region" }
    },
    "evidence_hints": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["crop", "ela_heatmap", "metadata_snapshot", "pdf_object_ref", "ocr_snippet", "overlay", "comparison_side_by_side"]
      }
    },
    "quality_sensitive": { "type": "boolean" },
    "limitations": { "type": "string" },
    "duration_ms": { "type": "integer", "minimum": 0 }
  }
}
