{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kycshield.ai/schemas/v1/finding.schema.json",
  "title": "Finding",
  "type": "object",
  "required": [
    "schema_version",
    "finding_id",
    "document_id",
    "document_type",
    "category",
    "title",
    "description",
    "severity",
    "confidence",
    "confidence_qualifier",
    "signals_triggered",
    "evidence_refs"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "finding_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "document_type": { "type": "string", "enum": ["aadhaar", "pan", "bank_statement"] },
    "category": {
      "type": "string",
      "enum": [
        "visual_forgery",
        "metadata_manipulation",
        "content_manipulation",
        "layout_manipulation",
        "synthetic_generation",
        "quality_gate"
      ]
    },
    "title": { "type": "string", "maxLength": 120 },
    "description": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "critical"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_qualifier": { "type": "string", "enum": ["high", "medium", "low"] },
    "signals_triggered": {
      "type": "array",
      "items": { "type": "string", "pattern": "^S[0-9]{2}$" },
      "minItems": 1
    },
    "regions": {
      "type": "array",
      "items": { "$ref": "#/$defs/region" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "limitations": { "type": "string" },
    "benign_alternatives": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "region": {
      "type": "object",
      "required": ["page_index", "bbox"],
      "properties": {
        "page_index": { "type": "integer", "minimum": 0 },
        "bbox": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "field_name": { "type": "string" }
      }
    }
  }
}
