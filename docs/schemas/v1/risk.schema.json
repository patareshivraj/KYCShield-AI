{
  "$id": "https://kycshield.ai/schemas/v1/risk.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentRiskAssessment",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "assessment_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "risk_level": { "type": "string", "enum": ["LOW", "MODERATE", "HIGH", "CRITICAL"] },
    "executive_summary": { "type": "string" },
    "investigator_summary": { "type": "string" },
    "technical_summary": { "type": "string" },
    "factors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "factor_name": { "type": "string" },
          "contribution_score": { "type": "number" },
          "description": { "type": "string" }
        }
      }
    },
    "critical_clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cluster_id": { "type": "string", "format": "uuid" },
          "rank": { "type": "integer" },
          "risk_contribution_score": { "type": "number" },
          "explanation": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["schema_version", "assessment_id", "document_id", "risk_score", "risk_level"],
  "additionalProperties": false
}
