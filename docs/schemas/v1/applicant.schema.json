{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kycshield.ai/schemas/v1/applicant.schema.json",
  "title": "Applicant",
  "type": "object",
  "required": ["schema_version", "applicant_id", "job_id", "status", "documents", "completeness", "created_at", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "applicant_id": { "type": "string", "format": "uuid" },
    "external_reference": { "type": "string" },
    "job_id": { "type": "string", "format": "uuid" },
    "status": {
      "type": "string",
      "enum": ["uploaded", "queued", "processing", "analyzed", "scored", "reported", "failed", "inconclusive"]
    },
    "documents": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "completeness": {
      "type": "object",
      "required": ["aadhaar", "pan", "bank_statement", "missing"],
      "properties": {
        "aadhaar": { "type": "boolean" },
        "pan": { "type": "boolean" },
        "bank_statement": { "type": "boolean" },
        "missing": {
          "type": "array",
          "items": { "type": "string", "enum": ["aadhaar", "pan", "bank_statement"] }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
