{
  "$id": "https://kycshield.ai/schemas/v1/noise.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NoiseResult",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "noise_id": { "type": "string", "format": "uuid" },
    "document_id": { "type": "string", "format": "uuid" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "signal_id": { "type": "string" },
          "finding_type": { "type": "string" },
          "severity": { "type": "string", "enum": ["INFO", "LOW", "MEDIUM", "HIGH"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
          "region_statistics": { "type": "object" },
          "supporting_signals": { "type": "array", "items": { "type": "string" } },
          "heatmap_reference": { "type": "string" }
        },
        "required": ["signal_id", "finding_type", "severity", "confidence", "bbox", "region_statistics"]
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["schema_version", "noise_id", "document_id", "findings", "created_at"],
  "additionalProperties": false
}
